{
  "extends": "ts-config-single-spa",
  "compilerOptions": {
    "jsx": "react-jsx",
    "declarationDir": "dist",
    "allowJs": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@aot-technologies/formiojs": ["node_modules/@aot-technologies/formiojs/lib/index.d.ts"],
      "@aot-technologies/formiojs/*": ["node_modules/@aot-technologies/formiojs/lib/*"]
    }
  },
  "files": ["src/formsflow-components.ts"],
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test*"]
}
